# API URL of the backend server
# Use http://localhost:5000 if running on simulator/emulator on the same machine.
# If running on a physical mobile device, use your local machine's IP (e.g., http://192.168.1.100:5000).
EXPO_PUBLIC_API_URL="http://localhost:5000"

# Google Client ID for OAuth login (must match the backend config)
EXPO_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
