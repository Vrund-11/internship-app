generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String        @id @default(cuid())
  phone     String        @unique
  createdAt DateTime      @default(now())

  sessions  UserSession[]
  pets      Pet[]
  addresses Address[]
  bookings  Booking[]
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OTP {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
}

model City {
  id       String  @id @default(cuid())
  name     String
  state    String
  isActive Boolean @default(true)

  bookings Booking[]
  partners Partner[]
}

model Booking {
  id          String   @id @default(cuid())
  userId      String
  cityId      String
  serviceType String
  petId       String
  addressId   String
  status      String   @default("SEARCHING_PARTNER")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  city City @relation(fields: [cityId], references: [id])
}

model Pet {
  id     String @id @default(cuid())
  userId String
  name   String

  user User @relation(fields: [userId], references: [id])
}

model Address {
  id     String @id @default(cuid())
  userId String
  text   String

  user User @relation(fields: [userId], references: [id])
}

model Partner {
  id                     String   @id @default(cuid())
  name                   String
  phone                  String   @unique
  cityId                 String
  isOnline               Boolean  @default(false)
  isVerified             Boolean  @default(true)
  activeBookings         Int      @default(0)
  todayCompletedBookings Int      @default(0)
  createdAt              DateTime @default(now())

  city     City             @relation(fields: [cityId], references: [id])
  services PartnerService[]
}

model PartnerService {
  id          String @id @default(cuid())
  partnerId   String
  serviceType String

  partner Partner @relation(fields: [partnerId], references: [id])
}
