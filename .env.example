# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"

# JSON Web Token Secret (can be any long random string)
JWT_SECRET="your-jwt-secret-key-change-this-in-production"

# Backend Server Port (defaults to 5000)
PORT=5000

# Redis Connection URL (defaults to redis://localhost:6379 if not specified)
REDIS_URL="redis://localhost:6379"

# Resend Email Service API Key (optional, for email notifications)
RESEND_API_KEY="your-resend-api-key"

# Google Client Credentials (optional, for social login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/login"

# Razorpay credentials (for payment integration)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Frontend Application URL (defaults to http://localhost:3000)
FRONTEND_URL="http://localhost:3000"
