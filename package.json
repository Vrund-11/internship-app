{
  "name": "canovet",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev:user": "npm run dev -w apps/user-app",
    "dev:backend": "npm run dev -w backend",
    "dev": "concurrently \"npm run dev:user\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
