{
  "name": "canovet",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev:user": "npm run dev -w apps/user-app",
    "dev:backend": "npm run dev -w backend",
    "dev:mobile": "npm run dev -w apps/mobile",
    "build:mobile-apk": "npm run build:apk -w apps/mobile",
    "build:backend": "npm run build -w backend",
    "start:backend": "npm run start -w backend",
    "dev": "concurrently \"npm run dev:user\" \"npm run dev:backend\"",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx ts-node backend/src/scripts/seed-all.ts"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
